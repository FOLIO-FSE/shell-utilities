#!/usr/bin/bash
auth 2>/dev/null || authn 2>/dev/null

tenant=$(cat tenant)
okapi_url=$(cat okapi.url)
okapi_token=$(cat okapi.token)

fines_file="fines.tsv"
logfile="feefine.log"
num_retrieved=1000
SECONDS=1

rm -f ${logfile}

uuids_in_source="no"
generate_uuids="no"

sed -i 's/"//g' "${fines_file}"

# FeeFine owner must be defined in /settings/users/owners
default_fine_owner="19755629-7c62-430d-98ad-47b4d64450f9"

declare -a owner_arr

owner_arr["Circulation"]="19755629-7c62-430d-98ad-47b4d64450f9"

id=$(curl -s -w '\n' -X GET -H "Accept: application/json" -H "X-Okapi-Tenant: ${tenant}" -H "x-okapi-token: ${okapi_token}" "${okapi_url}/owners/${default_fine_owner}" |jq -r .id)
if [[ $id != "${default_fine_owner}" ]];then echo "Default fine owner not located. Exiting program";exit;fi

# FeeFine type should be defined in /settings/users/feefinestable
feeFineType="Migrated fine"

retrieve_users() {
	records-get users	
	# load user uuids into scalar array keyed by barcode 
	eval "$(jq -r '@sh "user_dict[\(.barcode|tostring)]=\(.id|tostring)"' users.json)"
}
declare -A user_dict 

if [[ ${uuids_in_source} != "yes" && ${generate_uuids} != "yes" ]];then retrieve_users;fi

create_fine() {

patron_barcode=${patron_barcode//[^0-9A-Za-z\-]/}
fineamount=${fineamount//[^0-9\.]/}
item_charge=${item_charge//[^0-9\.]/}
processing_fee=${processing_fee//[^0-9\.]/}
billing_fee=${billing_fee//[^0-9\.]/}

feeFineId=$(uuid)
fineId=$(uuid)
actionId=$(uuid)

IFS='' read -r -d '' fine << EndOfJSON
{
  "ownerId": "${fine_owner}",
  "feeFineId": "${feeFineId}",
  "paymentStatus":{"name":"Outstanding"},
  "status":{"name":"Open"},
  "amount": "${fineamount}",
  "barcode": "${item_barcode}", 
  "dueDate": "${due_date}",
  "returnedDate": "${returned_date}",
  "remaining": "${fineamount}",
  "feeFineType": "${feeFineType}",
  "id": "${fineId}",
  "userId": "${userid}"
}
EndOfJSON

IFS='' read -r -d '' action << EndOfJSON
{
  "dateAction":"$(date -Is)",
  "typeAction":"Migration",
  "accountId": "${fineId}",
  "amountAction": "${fineamount}",
  "balance":"${fineamount}",
  "transactionInformation":"",
  "comments": "${notes}",
  "notify":false, 
  "id": "${actionId}",
  "userId": "${userid}"
}
EndOfJSON
}

counter=1
badbarcodes=0

numloans=$(cat ${fines_file} |wc -l)
item_barcode=""

while IFS=$'\n' read -r line; do
	line=$(tr "\t" "^" <<< "${line}")

	if [[ $SECONDS -gt 500 ]]; then
		auth 2>/dev/null || authn 2>/dev/null
		okapi_token=$(cat okapi.token)
		SECONDS=1
		OFFSET=$(($OFFSET + 1))
	fi
	# required fields: patron_barcode fine_amount
	#
	#IFS=$'^' read -r patron_barcode item_charge item_barcode fee_assess_date fineamount <<< "${line}"
	#
	#IFS=$'^' read -r patron_identifier fineamount fine_owner patron_barcode item_identifier item_barcode out_date due_date description notes  <<< "${line}"
	IFS=$'^' read -r patron_barcode description fineamount fee_assess_date  <<< "${line}"

	notes="Migrated fine"

	[[ -z $patron_barcode ]] && patron_barcode="${patron_identifier}"
	if [[ -v ${fine_owner} ]];then  fine_owner=${owner_arr[${fine_owner}]}; else fine_owner=${default_fine_owner};fi

	[[ ${description} =~ ^[0-9a-zA-Z]$ ]] && notes="${description} ${notes}"
	[[ ${fee_assess_date} =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] && notes="${notes}. Assessed:  ${out_date}"
	[[ ${out_date} =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] && notes="${notes}. Checkout date:  ${out_date}"
	[[ ${due_date} =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] && notes="${notes} Due date: ${due_date}"
	[[ ${returned_date} =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] && notes="${notes} Returned date: ${returned_date}"

	echo -en "Processing record $counter of ${numloans}. Bad barcodes found: ${badbarcodes}\r"

	if [[ ${generate_uuids} == "yes" ]];then 
		if [[ ${patron_barcode} =~ [a-zA-Z0-9] ]];then
			user_dict[${patron_barcode}]=$(uuid -v 5  8405ae4d-b315-42e1-918a-d1919900cf3f $(cat tenant):users:${patron_barcode})
		fi
	fi	
	if [[ ${uuids_in_source} == "yes" ]];then 
		user_dict[${patron_barcode}]=${patron_barcode}
	fi	

if [[ ${user_dict[${patron_barcode}]} =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]];then
	userid=${user_dict[${patron_barcode}]}
	create_fine
	account_data=$(curl --http1.1 -s -w '\n' -X POST -H "Content-type: application/json" -H "X-Okapi-Tenant: ${tenant}" -H "x-okapi-token: ${okapi_token}" -d "${fine}" "${okapi_url}/accounts")
	echo -e "${account_data//$'\n'/ }" >> ${logfile}

	feefine_data=$(curl --http1.1 -s -w '\n' -X POST -H "Content-type: application/json" -H "X-Okapi-Tenant: ${tenant}" -H "x-okapi-token: ${okapi_token}" -d "${action}" "${okapi_url}/feefineactions")
	
	echo -e "${feefine_data//$'\n'/ }" >> ${logfile}
else
	badbarcodes=$(($badbarcodes + 1))
	echo -e "Barcode not found\t${patron_barcode}" >> ${logfile}
fi

	notes=""

counter=$(($counter + 1))

done < ${fines_file}
echo 
echo "Processing completed"

echo "$badbarcodes barcodes were not found. Server responses are output to ${logfile}"

### convert indexed array to associative array

IFS=$'\t' read -r -a hdr < <(head -n 1 -- "$infile")
declare -A header_arr
declare -A fields_processed_arr

for i in "${!hdr[@]}"; do header_arr["${hdr[$i]}"]="${hdr[$i]}";done

addfield() {
	newfield="{\"folio_field\":\"${1}\",\"legacy_field\":\"${field}\",\"value\":\"\"}"
	object_map=$(jq --argjson NEWFIELD "${newfield}" '.data += [ $NEWFIELD ]' <<< "${object_map}")
}

addbackupfield() {
	newfield="{\"folio_field\":\"${1}\",\"legacy_field\":\"${field}\",\"value\":\"\",\"fallback_legacy_field\":\"${2}\"}"
	object_map=$(jq --argjson NEWFIELD "${newfield}" '.data += [ $NEWFIELD ]' <<< "${object_map}")
}

addvalue() {
	value="${2}"
	newfield="{\"folio_field\":\"${1}\",\"legacy_field\":\"${field}\",\"value\":\"${2}\"}"
	newfield=$(sed 's/"\(true\|false\)"/\1/' <<< "${newfield}")
	object_map=$(jq --argjson NEWFIELD "${newfield}" '.data += [ $NEWFIELD ]' <<< "${object_map}")
}

addreplacerules() {
	replace_rule="${2}"
	[[ "${2}" == "truefalse" ]] && replace_rule='"Yes":"true","YES":"true","Y":"true","y":"true","n":"false","N":"false","TRUE":"true","No":"false","NO":"false","FALSE":"false"'

	newfield="{\"folio_field\":\"${1}\",\"legacy_field\":\"${field}\",\"value\":\"\",\"rules\":{\"replaceValues\":{${replace_rule}}}}"
	object_map=$(jq --argjson NEWFIELD "${newfield}" '.data += [ $NEWFIELD ]' <<< "${object_map}")
}

addregexrules() {
	regex_rule="${2}"
	[[ "${2}" == "currency" ]] && regex_rule='([0-9]+\\.[0-9]{2})'
	[[ "${2}" == "email" ]] && regex_rule='(^[a-zA-Z0-9_\\-\\.]+@[a-zA-Z0-9_\\-\\.]+)'
	[[ "${2}" == "number" ]] && regex_rule='([0-9]+)'
	[[ "${2}" == "url" ]] && regex_rule='(^http.*)'

	newfield="{\"folio_field\":\"${1}\",\"legacy_field\":\"${field}\",\"value\":\"\",\"rules\":{\"regexGetFirstMatchOrEmpty\":\"${regex_rule}\"}}"
	object_map=$(jq --argjson NEWFIELD "${newfield}" '.data += [ $NEWFIELD ]' <<< "${object_map}")
}

default_field() {
  local target_folio_field="$1"
  local source_folio_field="$2"

  object_map=$(jq --arg target "$target_folio_field" --arg source "$source_folio_field" '
	if any(.data[]; .folio_field == $target) then
	  .
	else
	  .data += [{
		folio_field: $target,
		legacy_field: (
		  first(
			.data[]
			| select(.folio_field == $source)
			| .legacy_field
		  )
		)
	  }]
	end
  ' <<< "${object_map}")
}

default_value() {
  local key="$1"
  local value="$2"

  object_map=$(jq --arg key "$key" --arg value "$value" '
  	def maybe_number:
  		($value | try tonumber catch $value);	

	.data |= map(
	  if .folio_field == $key
	  then . + { value: (maybe_number) }
	  else .
	  end
	)
  ' <<< "${object_map}")
}

fallback_value() {
  local key="$1"
  local value="$2"
  object_map=$(jq --arg key "$key" --arg value "$value" '
  	def maybe_number:
  		($value | try tonumber catch $value);	

	.data |= map(
	  if .folio_field == $key
	  then . + { fallback_value: (maybe_number) }
	  else .
	  end
	)
  ' <<< "${object_map}")
}
fallback_field() {
  local key="$1"
  local value="$2"

  object_map=$(jq --arg key "$key" --arg value "$value" '
	.data |= map(
	  if .folio_field == $key
	  then . + { fallback_legacy_field: $value }
	  else .
	  end
	)
  ' <<< "${object_map}")
}

initialize() {
	object_map='{"data":[]}'
	outfile="${filetype}_mapping.json"
}

print_results() {
	jq '.data |= (sort_by(.folio_field) | map(. + {description: ""}))' <<< "${object_map}" > "${outfile}"
	{
	  echo -e "Legacy field\tFOLIO field"
	  jq -r '.data[] | [.legacy_field, .folio_field] | @tsv' "${outfile}"
	} > tmpmap
	
	echo "MAPPED and UNMAPPED fields from ${infile} output to ${outfile}"
	echo "Delimited map templates have been created"
	echo
	
	jq -r '.data[].legacy_field' "${outfile}" | sort -u > tmp1
	head -1 "${infile}" | tr '\t' '\n' | sort -u > tmp2
	awk -v FS='\t' '
	  NR==FNR { seen[$1]=1; next }
	  !($1 in seen) { print $1 }
	' tmp1 tmp2 > tmpunmapped1
	
	{
	  echo "UNMAPPED legacy fields found in ${infile}"
	  cat tmpunmapped1
	} > tmpunmapped2
	
	paste -d $'\t' tmpmap tmpunmapped2 | column -t -s $'\t'
	
	rm -f tmp1 tmp2 tmpunmapped1 tmpunmapped2 tmpmap
}

build_order_map() {
	for field in "${header_arr[@]}"; do
		comp_field=$(echo "${field,,}" | tr -dc [a-z0-9] |sed 's/folio//' )
	
		case ${comp_field} in
		  acquisitionmethod | form )
				if [[ -z ${acqMethod} ]];then
					addfield compositePoLines[0].acquisitionMethod
					acqMethod="${field}"
				fi
			;;
		  acquisitionunit | acquisitionunits )
				addfield acqUnitIds[0]
			;;
		  approved )
					addreplacerules approved truefalse
			;;
		  currency )
				currencyFile="${field}"
				addfield compositePoLines[0].cost.currency
			;;
		 	eprice | price | listunitprice | polineestimatedprice | unitprice )
				if [[ -z ${costField} ]];then
					addregexrules compositePoLines[0].cost.listUnitPrice currency
					fallback_value compositePoLines[0].cost.listUnitPrice "0.00"
					addregexrules totalEstimatedPrice currency
					fallback_value totalEstimatedPrice "0.00"
					costField="${field}"
				fi
			;;
		  listunitpriceelectronic )
				if [[ -z ${costField} ]];then
					addregexrules compositePoLines[0].cost.listUnitPriceElectronic currency
					fallback_value compositePoLines[0].cost.listUnitPriceElectronic "0.00" 
					addfield compositePoLines[0].cost.currency
					default_value compositePoLines[0].cost.currency USD
					addregexrules totalEstimatedPrice currency
					fallback_value totalEstimatedPrice "0.00"
					costField="${field}"
				fi
			;;
		  listunitpricephysical )
				addregexrules compositePoLines[0].cost.listUnitPricePhysical currency
				fallback_value compositePoLines[0].cost.listUnitPricePhysical "0.00" 
				default_value compositePoLines[0].cost.currency USD
			;;
		  costquantityelectronic | quantityelectronic )
				addregexrules compositePoLines[0].cost.quantityElectronic number
			;;
		  costquantityphysical | quantity | quantityphysical )
				addregexrules compositePoLines[0].cost.quantityPhysical number
				fallback_value compositePoLines[0].cost.quantityPhysical 1
			;;
		  descriptionreceivingnote | detailsreceivingnote | receivingnote | receivingcheckinitems )
				addfield compositePoLines[0].details.receivingNote
			;;
		  detailsisacknowledged | isacknowledged )
				addreplacerules compositePoLines[0].details.isacknowledged truefalse
			;;
		  url )
					addregexrules compositePoLines[0].details.resourceUrl url
			;;
		  startdate )
				addfield compositePoLines[0].details.subscriptionFrom
			;;
		  expirationdate )
				addfield compositePoLines[0].details.subscriptionTo
			;;
		  detailslinedescription | polinenote | polnote | polinedescription | productid | productidtype )
				addfield compositePoLines[0].description
			;;
		  userlimit | vendorreferencenumber | vendorreferencenumbers | vendorreferencetype )
				addfield compositePoLines[0].description
				addvalue compositePoLines[0].description "(${field})"
			;;
		  bibid | bibno | mmsid | mmsrecordid | recordbiblio | recordbibliographic | recordnumberbibliographic | systemidentifierbibid )
			addfield compositePoLines[0].instanceId
			;;
		  location | locationcode | locationid | locationidcode )
				addfield compositePoLines[0].locations[0].locationId
				locationfield="${field}"
			;;
		  copies | quantity | quantitytotal | totalitems )
				addregexrules compositePoLines[0].locations[0].quantity number
				addregexrules compositePoLines[0].cost.quantityPhysical number
			;;
		  locationquantityelectronic | quantityelectronic )
				addregexrules compositePoLines[0].locations[0].quantityElectronic number
			;;
		  locationquantityphysical | quantityphysical )
				addregexrules compositePoLines[0].locations[0].quantityPhysical number
			;;
		  format | orderformat )
				if [[ -z ${orderFormat} ]];then
					addfield compositePoLines[0].orderFormat
					fallback_value orderFormat "Physical Resource"
					addreplacerules orderFormat '"print":"Physical Resource","Print":"Physical Resource","database":"Electronic Resource","Database":"Electronic Resource","online":"Electronic Resource","Online":"Electronic Resource","print+online":"P/E Mix"'
				fi
			;;
		  publishername )
				addfield compositePoLines[0].publisher
			;;
		  requester )
				addfield compositePoLines[0].requester
			;;
		  polselector | selector )
				addfield compositePoLines[0].selector
			;;
		  title | titleorpackage )
				addfield compositePoLines[0].titleOrPackage
			;;
		  approvaldate | dateordered | invoicedate | odate | podate )
			addfield dateOrdered
			;;
		  expenseclass | expenseclassidcode | fund | fundcode | fundidcode | ordersubtype | libraryinformationpoordersubtype | vendorinstruction )
				addfield notes[${note_iter}]
				addvalue notes[${note_iter}] "(${field})"
				note_iter=$(($note_iter + 1))
			;;
		  note | noteorder | ordernote | descriptioninternalnote | notesnote1 | notesnote2 )
				addfield notes[${note_iter}]
				note_iter=$(($note_iter + 1))
			;;
		  intnote | ongoingnote )
				addfield ongoing.notes
			;;
		  ongoingissubscription )
				addreplacerules ongoing.isSubscription truefalse
			;;
		  manualpo | ongoingmanualrenewal )
				addreplacerules ongoing.manualRenewal truefalse
			;;
		  lineitemtype | ordtype | ordertype )
				if [[ -z ${ordType} ]]; then
					addreplacerules orderType '"Approval Plan":"One-Time","Continuation":"Ongoing","Depository":"One-Time","Firm Order":"One-Time","Gift":"One-Time","m":"One-Time","one-time":"One-Time","ongoing":"Ongoing","r":"Ongoing","Single-part":"One-Time","Standing order":"Ongoing","Subscription":"Ongoing"'
					addreplacerules ongoing.isSubscription '"Single-part":"false","Subscription":"true","Standing order":"false","m":"false","r":"true","y":"true"'
					addvalue ongoing.manualRenewal true
				fi
			;;
		  almapoline | ordernumber | po | ponumber | purchaseordernumber | recordorder )
				addfield poNumber
				addfield legacyIdentifier
				addvalue compositePoLines[0].source API
				primary_key="${field}"
			;;
		  poprefix )
				addfield poNumberPrefix
			;;
		  posuffix )
				addfield poNumberSuffix
			;;
		  reencumber | renewaldate )
				addreplacerules reEncumber truefalse
			;;
		  totalcost | totalprice )
				addregexrules totalEstimatedPrice currency
			;;
				organization | vendor | vendorcode )
				addfield vendor
				vendorfield="${field}"
			;;
		  vennote )
				addfield vendorDetail.noteFromVendor 
			;;
		  workflowstatus )
				addvalue workflowStatus Pending
				workflowStatus="${field}"
			;;
		esac
	done

	if [[ -z ${acqMethod} ]];then
		acqMethod="${primary_key}"
		default_field compositePoLines[0].acquisitionMethod poNumber
	fi

	if [[ -z ${costField} ]];then
		default_field compositePoLines[0].cost.listUnitPrice poNumber
		default_value compositePoLines[0].cost.listUnitPrice "0.00"
		default_field compositePoLines[0].cost.currency poNumber
		default_value compositePoLines[0].cost.currency USD
		default_field totalEstimatedPrice poNumber
		default_value totalEstimatedPrice "0.00"
	fi

	[[ -z ${orderFormat} ]] && default_field compositePoLines[0].orderFormat poNumber
	[[ -z ${orderFormat} ]] && default_value compositePoLines[0].orderFormat "Physical Resource"

	[[ -z ${ordType} ]] && default_field orderType poNumber
	[[ -z ${ordType} ]] && default_value orderType Ongoing

	[[ -z ${workflowStatus} ]] && default_field workflowStatus poNumber
	[[ -z ${workflowStatus} ]] && default_value workflowStatus Pending

	[[ -n ${vendorfield} ]] && echo -e "${vendorfield}\tfolio_code\n" > organizationCodeMap.tsv

	[[ -n ${acqMethod} ]] && echo -e "${acqMethod}\tfolio_value\nApproval\tApproval Plan\nApproval plan\tApproval Plan\nDemand Driven Acquisitions (DDA)\tDemand Driven Acquisitions (DDA)\nDepository\tDepository\nExchange\tExchange\nFirm Order\tPurchase\nFree\tFree\nGift\tGift\ni\tInternal transfer\nMembership\tMembership\nMembership Title\tMembership\na\tApproval Plan\nc\tPurchase\nm\tMembership\nn\tPurchase\np\tPurchase\nPurchase at vendor system\tPurchase at vendor system\nt\tPurchase\nv\tPurchase At Vendor System\n*\tOther" > acquisitionMethodMap.tsv
	[[ -n ${locationfield} ]] && echo -e "${locationfield}\tfolio_code\n*\tmigration" > locations_orders.tsv
}

build_holdings_map() {
	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")
	
		case ${comp_field} in 
			accession | accessionnumber)
				addfield accessionNumber 
				;;
			bibid | bibno | mmsid | mmsrecordid | recordbiblio | recordbibliographic | recordnumberbibliographic | systemidentifierbibid )
				addfield instanceId
				bibfield="${field}"
				;;
			id | itemid | itempid | physicalitemid | recorditem | z30reckey)
				addfield legacyIdentifier
				itemfield="${field}"
				;;
			callitem | permanentcallnumber | shelfmark )
				addfield callNumber 
				callfield="${field}"
				;;
			holdid | holrecordid | holdingsid | mfhdid | z30holdocunumber )
				addfield holdingsRecordId 
				holdidfield="${field}"
			;;
			holdings | libhas | libhascheckin | summaryholding | summaryholdings )
				addfield holdingsStatements[0].statement
			;;
			itempermanentlocation | itemshelvinglocation | permlocation | permanentlocation | permanentphysicallocation )
				addfield permanentLocationId
				locationfield="${field}"
			;;
		esac
	done

	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")
	
		case ${comp_field} in 
			call | callmarc | callno | callnumber )
				if [[ -z ${callfield} ]];then
					callfield=${field}
					addfield callNumber
				fi	
			;;
			callprefix | callnumberprefix )
				addfield callNumberPrefix
			;;
			callsuffix | callnumbersuffix )
				addfield callNumberPrefix
			;;
			oclc | oclcnumber )
				if [[ -z ${bibfield} ]];then
					bibfield=${field}
					addfield instanceId
				fi	
			;;
			loc | location )
				if [[ -z ${locationfield} ]];then
					addfield permanentLocationId
					locationfield=${field}
				fi	
			;;
		esac
	done

	# extra sweep to pull up bib specific call numbers

	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")
	
		case ${comp_field} in 
			bibcall | callbiblio | callbibliographic | callnonmarc )
				if [[ -z ${callfield} ]];then
					callfield=${field}
					addfield callNumber
				fi	
			;;
		esac
	done

	if [[ -z ${holdidfield} ]];then
		field=${itemfield}
		addfield formerIds[0]
	fi

	[[ -n ${callfield} ]] && echo -e "folio_name\t${callfield}\nLibrary of Congress classification\t1Library of Congress classification\t*" > call_number_type_mapping.tsv
	[[ -n ${typefield} ]] && echo -e "${mattypefield}\tfolio_name\n*\tmigration" > material_types.tsv
	[[ -n ${locationfield} ]] && echo -e "${locationfield}\tlegacy_code\tfolio_code\n*\t*\tmigration" > locations.tsv
}

build_item_map() {
	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")
	
		case ${comp_field} in 
			id | itemid | itempid | physicalitemid | recorditem | recordnumberitem | z30reckey)
				addfield legacyIdentifier
				itemfield="${field}"
				;;
			barcode | itembarcode | z30barcode )
				addfield barcode
				barcodefield="${field}"
			;;
			holdid | holrecordid | holdingsid | mfhdid | z30holdocunumber )
				addfield holdingsRecordId 
				holdidfield="${field}"
			;;
			materialformat | materialtype | mattype | mtype | mediaitm | z30material )
				addfield materialTypeId 
				mattypefield="${field}"
			;;
			loantype | itempolicy | icode2 )
				addfield permanentLoanTypeId 
				loantypefield="${field}"
			;;
			fulfillmentnote | imessage | imsg | message | checkinnote )
				addfield circulationNotes[${chkinnote_iter}].note
				addvalue circulationNotes[${chkinnote_iter}].noteType "Check in"
				addvalue circulationNotes[${chkinnote_iter}].staffOnly true
				chkinnote_iter=$(($chkinnote_iter + 1))
			;;
			internalnote | intnote | price | staffnote )
				addfield notes[${note_iter}].note
				addvalue notes[${note_iter}].itemNoteTypeId xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
				addvalue notes[${note_iter}].staffOnly true
				note_iter=$(($note_iter + 1))
			;;
			note | notegeneral | opacmsg | publicnote | z30noteopac )
				addfield notes[${note_iter}].note
				addvalue notes[${note_iter}].itemNoteTypeId xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
				addvalue notes[${note_iter}].staffOnly false
				note_iter=$(($note_iter + 1))
			;;
			copy | copynumber | copyno | copyid | z30copyid | itemcopyid )
				addfield copyNumber
			;;
			chron | chronology )
				addfield volume
			;;
			enum | enumeration | itemenum )
				addfield enumeration
			;;
			vol | volume )
				addfield volume
			;;
			year )
				addfield yearCaption[0]
			;;
			pieces)
				addfield numberOfPieces 
			;;
			itemstatus | itemstatusdesc | itemstatuscurrentstatus | status | statusmappingkey )
				addfield status.name
				statusfield="${field}"
			;;
			templocation | itemtemporaryshelvinglocation)
				addfield temporaryLocationId
			;;
			tempitemtype | temporaryitemtype | temploantype | temporaryloantype)
				addfield temporaryLoanTypeId
			;;
		esac
	done

	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")
	
		case ${comp_field} in 
			barcode | itembarcode | z30barcode )
				[[ -z ${itemfield} ]] && addfield legacyIdentifier
			;;
			itype | itemtypeid | itemtypecode | itemtypename)
				if [[ -z ${mattypefield} ]];then
					addfield materialTypeId
					mattypefield="${field}"
				fi
				if [[ -z ${loantypefield} ]];then
					addfield permanentLoanTypeId
					loantypefield="${field}"
				fi
			;;
		esac
	done

	if [[ -z ${holdidfield} ]];then
		field=${itemfield}
		addfield holdingsRecordId
	fi

	[[ -n ${mattypefield} ]] && echo -e "${mattypefield}\tfolio_name\n*\tmigration" > material_types.tsv
	[[ -n ${loantypefield} ]] && echo -e "${loantypefield}\tfolio_name\n*\tmigration" > loan_types.tsv
	echo -e "${item_statuses}" > item_statuses.tsv
}


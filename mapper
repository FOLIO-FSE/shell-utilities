			;;
			contactnote | contact1note )
				addfield contacts[0].notes
			;;
			description | orgnote | vendornote | vennote )
				addfield description
			;;
			email | preferredemail )
				addregexrules emails[0].value email
				addvalue emails[0].isPrimary true
				emailcategoryfield="${field}"
			;;
			accountcode | accountno | erpcode )
				addfield erpCode
			;;
			interfaceuri | url )
				addfield interfaces[0].uri
			;;
			isvendor | vendoryesno )
				addreplacerules isVendor truefalse
			;;
			name | orgname | providername | venname | vendorname )
				addfield name
			;;
			note | note1 | notes | notecontent | orgnote | special | vendornote | vennote )
				addfield notes[${note_iter}].content
				addvalue notes[${note_iter}].content organizations
				addvalue notes[${note_iter}].noteTypeId xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
				note_iter=$(($note_iter + 1))
			;;
			note2 | notes2 | notecontent2 | orgnote2 | vendornote2 | vennote2 )
				addfield notes[${note_iter}].content
				addvalue notes[${note_iter}].content organizations
				addvalue notes[${note_iter}].noteTypeId xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
				note_iter=$(($note_iter + 1))
			;;
			orgtype | vendortype )
				addfield organizationTypes[0]
				orgtypefield="${field}"
			;;
			paymentmethod )
				addfield paymentMethod
			;;
			phone | phone1 | phonenum | phonenumber | preferredphonenumber | tel | telephone )
				addfield phoneNumbers[${phone_iter}].phoneNumber
				addvalue phoneNumbers[${phone_iter}].type Office
				addvalue phoneNumbers[${phone_iter}].isPrimary true
				phone_iter=$(($phone_iter + 1))
				phonecategoryfield="${field}"
			;;
			fax | phone2 | phonenum2 | phonenumber2 | tel2 | telephone2 )
				addfield phoneNumbers[${phone_iter}].phoneNumber
				addvalue phoneNumbers[${phone_iter}].type Office
				addvalue phoneNumbers[${phone_iter}].isPrimary false
				phone_iter=$(($phone_iter + 1))
			;;
			orgstatus | orgstatusactiveinactivepending | status )
				addreplacerules status '"active":"Active","ACTIVE":"Active","inactive":"Inactive","INACTIVE":"Inactive","pending":"Pending","PENDING":"Pending"'
			;;
		esac
	done
	
	default_field status code
	default_value status Active

	[[ -z ${addresscategoryfield} ]] && echo -e "${addressfield}\tfolio_value\n*\tOffice" > address_categories.tsv

	[[ -n ${codefield} ]] && echo -e "${codefield}\tfolio_code\n" > organizationCodeMap.tsv
	[[ -n ${orgtypefield} ]] && echo -e "${orgtypefield}\tfolio_name\n*\tOffice" > organization_types.tsv
	[[ -n ${addresscategoryfield} ]] && echo -e "${addresscategoryfield}\tfolio_value\n*\tOffice" > address_categories.tsv
	[[ -n ${emailcategoryfield} ]] && echo -e "${emailcategoryfield}\tfolio_value\n*\tOffice" > email_categories.tsv
	[[ -n ${phonecategoryfield} ]] && echo -e "${phonecategoryfield}\tfolio_value\n*\tOffice" > phone_categories.tsv
}

build_user_map() {
	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")
	
		case ${comp_field} in 
			id | patronuniqueid | primaryidentifier | record | recordnumberpatron | uniqueid | userid | useruserid )
				addfield legacyIdentifier
				idfield="${field}"
				;;
			categorycode | group | mappedpatrongroup | patronborrowercategory | patrongroup | patrongroupcode | patrontype | ptype | ptypecode | type | usergroup | usergroupcode | userprofile )
				addfield patronGroup
				groupfield="${field}"
			;;
			note | notes | note_content | notepatron | patronnote | patronnotes | borrowernote |userxinfonote | comment )
				addfield notes[${note_iter}].note
				addvalue notes[${note_iter}].noteTypeId xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
				note_iter=$(($note_iter + 1))
			;;
			firstname | fname | givenname | patrongivenname )
				addfield personal.firstName 
				;;
			 middle | middlename | mname )
				addfield personal.lastName 
				;;
			 familyname | lastname | lname | patronfamilyname | surname )
				addfield personal.lastName 
				lnamefield="${field}"
				;;
			address1phone1 | homephone | patronphone | patronphonenumber | phone | phoneno | phonenumber | primaryphone | telephone )
				addfield personal.phone 
				;;
			 cellphone | mobile | mobilephone )
				addfield personal.mobilePhone 
				;;
			 email | emailaddr | emailaddress | emailaddress1 | patronemail  | patronemailaddress | primaryemail )
				addfield personal.email
				addregexrules personal.email email
				;;
			loginid | username )
				addfield username
				userfield="${field}"
				;;
			 addr1 | addr1line1 | address | address1 | address1line1 | addrline1 | homeadddress1 | permaddressline1 | primaryaddress )
				addfield personal.addresses[0].addressLine1
				addvalue personal.addresses[0].addressTypeId primary
				;;
			 addr2 | addr2line1 | address2 | address2 | address2line1 | addr2line1 )
				addfield personal.addresses[1].addressLine1
				addvalue personal.addresses[1].addressTypeId work
				;;
			 addr1city | address1city | city | homecity | permcity )
				addfield personal.addresses[0].city
				;;
			 addr2city | address2city | city2 )
				addfield personal.addresses[1].city
				;;
			 addr1zip | address1zip | homezip | patronpostalcode | permzip | postalcode | zip )
				addfield personal.addresses[0].postalCode
				;;
			 addr2zip | address2zip | postalcode2 | zip2 )
				addfield personal.addresses[1].postalCode
				;;
			 addr1state | address1state | homestate | patronprovince | permstate | region | state )
				addfield personal.addresses[0].region
				;;
			 addr2state | address2state | region2 | state2 )
				addfield personal.addresses[1].region
				;;
		esac
	done

	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")

		case ${comp_field} in 
			barcode | pbarcode | patronbarcode | cardnumber | borrowerid )
				if [[ -z ${idfield} ]];then
					addfield legacyIdentifier
					addfield barcode
					idfield=${field}
					barcodefield=${field}
				else
					addbackupfield barcode "${idfield}"
				fi
			;;
			patrnname | name )
				if [[ -z ${lastname} ]];then
					addfield personal.lastName
					addfield personal.firstName
				else
					addfield personal.firstName
				fi
			;;
		esac
	done

	for field in "${header_arr[@]}"; do
		comp_field=$(tr -dc [a-z0-9] <<< "${field,,}")
	
		case ${comp_field} in 
			univid | uniid | externalsystemid | studentid )
				if [[ -z ${barcode} ]];then
					addbackupfield barcode "${idfield}"
					field=${barcodefield}
				fi	
			;;
		esac
	done
	if [[ -z ${lastname} ]];then
		[[ -n ${firstname} ]] && lastname="${firstname}"
	fi
	[[ -n ${groupfield} ]] && echo -e "${groupfield}\tfolio_group\n*\tmigration" > user_groups.tsv
}
initialize

case ${filetype} in	
	composite_order)
		build_order_map
		print_results
		;;
	holdings)
		build_holdings_map
		print_results
		;;
	item)
		build_item_map
		print_results
		filetype="holdings"
		initialize
		build_holdings_map
		echo
		print_results
		;;
	organization)
		build_organization_map
		print_results
		;;
	user)
		build_user_map
		print_results
		;;

esac


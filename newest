
#!/usr/bin/bash

path="${1}"

if [[ -z "${path}" || ! -d "${path}" ]]; then
    path=$(mount -t fuse.s3fs 2>/dev/null | awk '{print $3}' | head -1)

    if [[ -z "${path}" ]]; then
        echo "No valid path provided and no s3fs mount found."
        echo "Please specify a path."
        exit 1
    fi

    echo "Using s3fs mount: ${path}"
fi

find "${path}" -type f -exec ls -lt {} + 2>/dev/null | head -10


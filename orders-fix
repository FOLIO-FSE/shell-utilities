infile="${1}"

fileroot=$(echo "${infile}" | sed 's/\.....\?$//')
outfile="${fileroot}_fixed.json"
tmpfile="${fileroot}_tmp"

echo
echo "This utility analyzes composite order object files created by the FOLIO migration tools."
echo "Usage: orders-fix [objectfile.json]"
echo

#cat "${infile}" |jq 'walk(if type == "object" and (.distributionType != null) and (.fundId == null) then del(.) else . end)' > "${tmpfile}1.json"

# add details object if not present
pv "${infile}" |sed 's/"\(true\|false\)"/\1/' | \
jq -c '.compositePoLines[] |= if .details==null then .details={} else . end |

	# delete invalid funds and expense classes
	walk(
	  if type == "object" then
	    if (.distributionType != null)
	       and (.fundId | test("^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$") | not)
	    then del(.) 
	    elif (has("expenseClassId")
	          and (.expenseClassId | test("^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$") | not))
	    then
	      del(.expenseClassId)    
	    else .  end else .  end) |

	# remove invalid characters from PO number
	if .poNumber != null then .poNumber = (.poNumber|gsub("[^a-zA-Z0-9]"; "")) else . end |

	# set subscription for ongoing orders
	if .orderType=="Ongoing" then (.ongoing.isSubscription = true | .ongoing.manualRenewal = false) else . end |

	# populated rest of fund object if fundId is correct
	walk(
	if type == "object" and .fundId 
	then (
	.distributionType = "percentage" |
	.value = 100
	)
	else . end |

	# and delete fundId mapped to note
	if type == "string" and (. |test("..[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$")) 
	then del(.)
	else . end |

	if type == "object" and .locationId and (.quantity |type == "string") 
	then (
	.quantity = (.quantity |tonumber) |
	if .quantity == 0 then .quantity = 1 else . end |
	.quantityPhysical = .quantity 
	)
	else . end |

	if type == "object" and (.quantityElectronic? != null) then
		.quantityElectronic |= tonumber?	
		| if .quantityElectronic == 0
			then del(.quantityElectronic)
			else . end
	else . end |

	if type == "object" and (.quantityPhysical |type == "string") 
	then (
	.quantityPhysical = (.quantityPhysical |tonumber) |
	if .quantityPhysical == 0 then .quantityPhysical = 1 else . end 
	)
	else . end)  |

	# delete empty arrays
	(.. | arrays) |= 
	if any(values) then map(values) else [] end | 
	del(..|select(. == [])) |

	# coordinate price info
	walk(
	if type == "object" and ((.cost.poLineEstimatedPrice == null) and (.cost.currency != null)) then 
	(.cost.poLineEstimatedPrice, .cost.listUnitPrice) = 0.00 
	else .  end |

	# fix currency if missing
	if type == "object" and .cost then
	  (
	    if .cost.currency == null then
	      .cost.currency = "USD"
	    else .  end
	    | .cost.currency |= ascii_upcase
	  )
	else .  end |

	# convert all prices to numbers
	if type == "object" then
	  (
	    with_entries(
	      if (.key | test("Price")) then
	        (.value | tonumber?) as $n
	        | if $n != null then
	            .value = $n
	          else
	            .
	          end
	      else
	        .
	      end
	    )
	  )
	else
	  .
	end |

	# fix other
	if type == "object" and .orderFormat == "Other" then
	  (
	    # ensure locations array exists
	    (.locations //= [])
	    | del(.cost.quantityElectronic)
	    | (.locations |= map(
	        del(.quantityElectronic)
	        | .quantity = (.quantityPhysical // 1)
	      ))
	  )
	else
	  .
	end |

	# fix physical
	if type == "object" and .orderFormat == "Physical Resource" then
	  (
	    # ensure locations array exists
	    .locations //= [] |
	    # remove electronic quantity at cost level
	    del(.cost.quantityElectronic) |
	    # update each location safely
	    .locations |= map(
	      del(.quantityElectronic)
	      | .quantity = (.quantityPhysical // 1)
	    )
	  )
	else
	  .
	end |

	# fix electronic
	if type == "object" and .orderFormat == "Electronic Resource" then (
	(.cost.listUnitPriceElectronic = .cost.listUnitPrice |del(.cost.listUnitPrice))
	| (.cost.quantityElectronic = .cost.quantityPhysical |del(.cost.quantityPhysical)) 
	| (.locations[].quantityElectronic = .cost.quantityElectronic| del(.locations[].quantityPhysical))
	| (.locations[].quantity = .locations[].quantityElectronic)
	)
	else . end |

	# fix p/e mix 
	if type == "object" and .orderFormat == "P/E Mix" then
	  (
	    .quantityPhysical //= 1 | .quantityElectronic //= 1
	    | .cost.listUnitPriceElectronic = 0
	    | (.locations[].quantityElectronic = .quantityElectronic)
	    | (.locations[].quantity =
	        ((.quantityPhysical | tonumber) + (.quantityElectronic | tonumber))
	      )
	  )
	else
	  .
	end)
' > "${outfile}"

echo
echo

noquantity=$(jq -r '.compositePoLines[]
        | select(
        (.locations[] | .quantityPhysical == null and .quantityElectronic == null)
        ) | [.instanceId, .titleOrPackage]|@tsv' "${outfile}")


if [[ -n "${noquantity}" ]];then
	echo "The following PO titles were not associated with a physical or electronic quantity"
	echo
	echo -e "${noquantity}"
	echo
fi

echo "A corrected file has been output to ${outfile}"


infile="${1}"

fileroot=$(echo "${infile}" | sed 's/\.....\?$//')
outfile="${fileroot}_fixed.json"
tmpfile="${fileroot}_tmp"

echo
echo "This utility analyzes composite order object files created by the FOLIO migration tools."
echo "Usage: orders-fix [objectfile.json]"
echo

# add details object if not present
pv "${infile}" |sed 's/"\(true\|false\)"/\1/' | \
jq -c '.compositePoLines |= map(
if .orderFormat == "Physical Resource" then
	(
	  ((.cost.quantityPhysical // 1) | tonumber) as $qp |
	
	  # ensure valid physical price
	  .cost.listUnitPrice = ((.cost.listUnitPrice // 0) | tonumber) |
	
	  # remove electronic-only fields
	  del(.cost.quantityElectronic) |
	  del(.cost.listUnitPriceElectronic) |
	
	  # quantities
	  .cost.quantityPhysical = $qp |
	
	  .locations //= [] |
	  .locations |= map(
	    .quantityPhysical = $qp |
	    del(.quantityElectronic) |
	    .quantity = $qp
	  )
	)
  elif .orderFormat == "Electronic Resource" then
  (
    ((.cost.quantityElectronic // .cost.quantityPhysical // 1) | tonumber) as $qe |

    .cost.quantityElectronic = $qe |
    .cost.listUnitPriceElectronic = ((.cost.listUnitPrice // 0) | tonumber) |
    del(.cost.listUnitPrice) |
    del(.cost.quantityPhysical) |

    .locations //= [] |
    .locations |= map(
      .quantityElectronic = $qe |
      del(.quantityPhysical) |
      .quantity = $qe
    )
  )

  elif .orderFormat == "P/E Mix" then
  (
    ((.cost.quantityPhysical // 1) | tonumber) as $qp |
    ((.cost.quantityElectronic // 1) | tonumber) as $qe |
    .cost.listUnitPrice = ((.cost.listUnitPrice // 0) | tonumber) |
    .cost.listUnitPriceElectronic = ((.cost.listUnitPriceElectronic // 0) | tonumber) |

    ($qp | if . < 1 then 1 else . end) as $qp_min |
    ($qe | if . < 1 then 1 else . end) as $qe_min |

    .cost.quantityPhysical = $qp_min |
    .cost.quantityElectronic = $qe_min |

    .locations //= [] |
    .locations |= map(
      .quantityPhysical = $qp_min |
      .quantityElectronic = $qe_min |
      .quantity = ($qp_min + $qe_min)
    )
  )

  else .
  end
) | .compositePoLines[] |= if .details==null then .details={} else . end 
	# set subscription for ongoing orders
	| (.orderType //= "Ongoing")
	| if .orderType == "Ongoing" then
	  .ongoing |= (
	    . // {}                      # create if missing
	    | .isSubscription = true
	    | .manualRenewal = false
	  )
	elif .orderType == "One-Time" then
	  del(.ongoing)
	else .  end |

	# delete bad fund distributions
	.compositePoLines |= map(
	  if (
	    (.fundDistribution? // [])
	    | all(.fundId? and (.fundId | test("^[0-9a-f-]{36}$")))
	  )
	  then
	    (
	      .fundDistribution |= (
	        (. // [])
	        | map(
	            .distributionType = "percentage"
	            | .value = 100
	            | if (.expenseClassId? and (.expenseClassId | test("^[0-9a-f-]{36}$") | not))
	              then del(.expenseClassId)
	              else .
	              end
	          )
	      )
	    )
	  else
	    del(.fundDistribution)
	  end
	) |
	walk(
	  if type == "object" then
    	with_entries(select(.value != []))
  	else .
  	end
	) |
	# coordinate price info
	walk(
	# fix currency if missing
	if type == "object" and .cost then
	  (
	    if .cost.currency == null then
	      .cost.currency = "USD"
	    else .  end
	    | .cost.currency |= ascii_upcase
	  )
	else .  end |
	# convert all prices to numbers
	if type == "object" then
	  (
	    with_entries(
	      if (.key | test("Price")) then
	        (.value | tonumber?) as $n
	        | if $n != null then
	            .value = $n
	          else
	            .
	          end
	      else
	        .
	      end
	    )
	  )
	else
	  .
	end 
	) | 
  # move createInventory into correct sub-object (physical or eresource)
  .compositePoLines |= map(
  (.createInventory // .physical.createInventory // .eresource.createInventory // null) as $ci |
  if $ci != null then
    del(.createInventory) |
    if .physical then (.physical |= del(.createInventory)) else . end |
    if .eresource then (.eresource |= del(.createInventory)) else . end |
    # clean up sub-objects left empty after removal
    if (.physical // null) == {} then del(.physical) else . end |
    if (.eresource // null) == {} then del(.eresource) else . end |
    # place in correct sub-object based on quantity
    if (.cost.quantityElectronic != null) then
      .eresource = ((.eresource // {}) + {createInventory: $ci})
    else
      .physical = ((.physical // {}) + {createInventory: $ci}) |
      .physical.volumes //= []
    end
  else
    if .physical and (.physical.volumes == null) then
      .physical.volumes = []
    else . end
  end)
' > "${outfile}"

echo
echo

noquantity=$(jq -r '.compositePoLines[]
        | select(
        (.locations[] | .quantityPhysical == null and .quantityElectronic == null)
        ) | [.instanceId, .titleOrPackage]|@tsv' "${outfile}")


if [[ -n "${noquantity}" ]];then
	echo "The following PO titles were not associated with a physical or electronic quantity"
	echo
	echo -e "${noquantity}"
	echo
fi

echo "A corrected file has been output to ${outfile}"


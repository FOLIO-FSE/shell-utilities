#!/usr/bin/env bash
set -euo pipefail

command -v curl >/dev/null || { echo "❌ curl required"; exit 1; }
command -v jq >/dev/null || { echo "❌ jq required"; exit 1; }

QUERY="${1:-}"
MODE="${2:-}"
ARG="${3:-}"

if [[ -z "$QUERY" ]]; then
  echo "Usage:"
  echo "  schema-get <module>"
  echo "  schema-get <module> schema (lists schema)"
  echo "  schema-get <module> schema <name>"
  echo "  schema-get <module> example <name>"
  echo "  schema-get <module> example-min <name> (only required fields)"
  exit 1
fi

HEADERS=(-H "Accept: application/vnd.github+json" -H "User-Agent: schema-get")
[[ -n "${GITHUB_TOKEN:-}" ]] && HEADERS+=(-H "Authorization: Bearer $GITHUB_TOKEN")

# ----------------------------
# MODULE RESOLUTION
# ----------------------------
Q=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')
BASE="${Q#mod-}"

# ✅ normalize common singular inputs
case "$BASE" in
  order-storage) BASE="orders-storage" ;;
  order) BASE="orders" ;;
  inventory) BASE="inventory-storage" ;;
esac

CANDIDATES=(
  "mod-$BASE"
  "$BASE"
  "mod-${BASE%-storage}"
  "mod-${BASE%-storage}-storage"
)

MODULE=""

for m in "${CANDIDATES[@]}"; do
  RESP=$(curl -s "${HEADERS[@]}" "https://api.github.com/repos/folio-org/$m")
  if [[ "$(echo "$RESP" | jq -r '.id // empty')" != "" ]]; then
    MODULE="$m"
    break
  fi
done

[[ -z "$MODULE" ]] && { echo "❌ Module not found"; exit 1; }

echo "🔍 Module: $MODULE"

# ----------------------------
# BRANCH
# ----------------------------
BRANCH=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE" \
  | jq -r '.default_branch // empty')

[[ -z "$BRANCH" ]] && BRANCH="master"

echo "🌿 Branch: $BRANCH"

# ----------------------------
# RAML FILES
# ----------------------------
RAML_FILES=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE/contents/ramls" \
  | jq -r '.[]? | select(.name|endswith(".raml")) | .path')

# ----------------------------
# FIND SCHEMA (FINAL FIXED)
# ----------------------------
find_schema() {
  local name="$1"
  name="${name%.json}"

  local best_match=""
  local best_score=0

  for file in $RAML_FILES; do
    CONTENT=$(curl -s \
      "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

		SCHEMAS=$(echo "$CONTENT" \
	  | grep -Eo '(schemas/[A-Za-z0-9._-]+\.json|[A-Za-z0-9._-]+\.json)' \
  	| grep -vE '\.raml|\.md|\.yaml|\.yml' \
  	| sort -u || true)

		# ✅ Ensure direct name is always a candidate
		REQUESTED_FILE="${name}.json"
		
		if ! echo "$SCHEMAS" | grep -q "$REQUESTED_FILE"; then
		  SCHEMAS="$SCHEMAS"$'\n'"$REQUESTED_FILE"
		fi

    for s in $SCHEMAS; do
      fname=$(basename "$s")
      base="${fname%.json}"

      score=0

      # ✅ exact match
      [[ "$base" == "$name" ]] && score=200

      # ✅ direct path match
      [[ "$s" == *"$name.json" ]] && score=180

      # ✅ composite
      [[ "$base" == "composite_$name" ]] && score=150

      # ✅ prefix match
      [[ "$base" == "$name"* ]] && score=100

      # ✅ contains fallback
      [[ "$base" == *"$name"* ]] && score=10

      # ❗ penalize collections heavily
      if [[ "$base" == *_collection ]]; then
        score=$((score - 150))
      fi

      # ✅ prefer shorter names
      score=$((score - ${#base} / 5))

      if (( score > best_score )); then
        best_score=$score
        best_match="$s"
      fi
    done
  done

  if [[ -n "$best_match" ]]; then
    echo "$best_match|$(basename "$best_match")"
  else
    echo "|"
  fi
}

# ----------------------------
# FETCH SCHEMA
# ----------------------------
fetch_schema() {
  local path="$1"
  local file="$2"
  local tmp="$3"
# normalize file to just filename
file=$(basename "$file")


# ----------------------------
# ✅ KNOWN SPECIAL CASES (FAST PATH)
# ----------------------------
case "${MODULE}:${file}" in
  # ✅ organizations
  mod-organizations-storage:organization.json | mod-organizations:organization.json)
    URL="https://raw.githubusercontent.com/folio-org/data-import-processing-core/master/ramls/settings/organization.json"
    HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL")
    if [[ "$HTTP" == "200" ]]; then
      echo "$URL"
      return 0
    fi
    ;;

esac

  # ----------------------------
  # ✅ 1. Try module repo paths
  # ----------------------------
  URL1="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$file"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL1")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL1"
    return
  fi

	# ----------------------------
	# ✅ Try schemas/ directory (CRITICAL for inventory)
	# ----------------------------
	URL_SCHEMAS="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/schemas/$file"
	# ----------------------------
	# ✅ Try nested schemas subdirs (inventory pattern)
	# ----------------------------
	if [[ "$MODULE" == "mod-inventory-storage" ]]; then
		for subdir in holdings-storage item-storage instance-storage; do
		  URL_SUB="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/schemas/$subdir/$file"
		  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL_SUB")
		
		  if [[ "$HTTP" == "200" ]]; then
		    echo "$URL_SUB"
		    return 0
		  fi
		done
	fi

	HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL_SCHEMAS")
	
	if [[ "$HTTP" == "200" ]]; then
	  echo "$URL_SCHEMAS"
	  return 0
	fi

  URL2="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$path"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL2")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL2"
    return
  fi

# ----------------------------
# ✅ 2. acq-models fallback (improved)
# ----------------------------
local base_module="${MODULE#mod-}"
base_module="${base_module%-storage}"

# ✅ try base module
URL3="https://raw.githubusercontent.com/folio-org/acq-models/master/mod-${base_module}/schemas/$file"
HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL3")

if [[ "$HTTP" == "200" ]]; then
  echo "$URL3"
  return 0
fi

# ✅ ✅ NEW: try storage variant
URL4="https://raw.githubusercontent.com/folio-org/acq-models/master/mod-${base_module}-storage/schemas/$file"
HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL4")

if [[ "$HTTP" == "200" ]]; then
  echo "$URL4"
  return 0
fi

  echo ""
}

# ============================
# SCHEMA MODE
# ============================
# ============================
# ✅ SCHEMA MODE (LIST + FETCH)
# ============================
if [[ "${MODE:-}" == "schema" ]]; then

  # ----------------------------
  # ✅ LIST SCHEMAS
  # ----------------------------
  if [[ -z "${ARG:-}" ]]; then
    echo
    echo "📦 Available schemas:"
    echo

    for file in $RAML_FILES; do
      CONTENT=$(curl -s \
        "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

      echo "$CONTENT" \
        | grep -Eo '(schemas/[A-Za-z0-9_./-]+\.json|[A-Za-z0-9_./-]+\.json)' \
				| grep -vE '\.raml|\.md|\.yaml|\.yml' \
        | sed -E 's#.*/##; s#\.json##'
    done | sort -u

    echo
    echo "💡 Usage:"
    echo "   schema-get $QUERY schema <name>"
    echo
    exit 0
  fi

  # ----------------------------
  # ✅ FETCH SINGLE SCHEMA
  # ----------------------------
  IFS="|" read SC_PATH SC_FILE <<< "$(find_schema "$ARG")"

  if [[ -z "$SC_FILE" ]]; then
    echo "❌ schema not found"
    exit 1
  fi

  TMP=$(/usr/bin/mktemp)
  URL=$(fetch_schema "$SC_PATH" "$SC_FILE" "$TMP")

  if [[ -z "$URL" ]]; then
    echo "❌ fetch failed"
    rm -f "$TMP"
    exit 1
  fi

  echo "📦 Schema: $SC_FILE"
  echo "🔗 URL: $URL"
  echo

  jq . "$TMP"

  rm -f "$TMP"
  exit 0
fi

# ============================
# EXAMPLE MODE
# ============================
if [[ "$MODE" == example* ]]; then
  [[ -z "$ARG" ]] && { echo "❌ provide schema name"; exit 1; }

  FULL=true
  [[ "$MODE" == "example-min" ]] && FULL=false

  IFS="|" read SC_PATH SC_FILE <<< "$(find_schema "$ARG")"
  [[ -z "$SC_FILE" ]] && { echo "❌ schema not found"; exit 1; }

  TMP=$(/usr/bin/mktemp)
  URL=$(fetch_schema "$SC_PATH" "$SC_FILE" "$TMP")
  [[ -z "$URL" ]] && { echo "❌ fetch failed"; exit 1; }

  echo "🧪 $( $FULL && echo Full || echo Minimal ) payload for: $SC_FILE"
	echo "🔗 Schema: $URL"
  echo

  jq --argjson full "$FULL" '

  def uuid: "00000000-0000-0000-0000-000000000000";

  def gen($full; $k):

    if has("items") or (.type? == "array") then []
    elif has("enum") then .enum
    elif (.type? == "boolean") then false
    elif (.type? == "integer") then 0
    elif (.type? == "number") then 0

    elif has("properties") then
      (.properties // {}) as $props
      | (.required // []) as $req
      | if $full then
          reduce ($props | keys_unsorted[]) as $p (
            {};
            . + { ($p): ($props[$p] | gen($full; $p)) }
          )
        else
          reduce $req[] as $p (
            {};
            . + { ($p): ($props[$p] | gen($full; $p)) }
          )
        end

    else
			if (has("$ref") and (.["$ref"] | test("uuid\\.json$"))) then
				uuid
      elif ($k|test("id$|Id$")) then
				uuid
			elif (.format? == "date-time") then
				"2026-01-01T12:00:00Z"
			elif (.type? == "object" and has("$ref")) then
				"<object:" + .["$ref"] + ">"
			elif (.type? == "string" and has("$ref")) then
				"<string:" + .["$ref"] + ">"
			elif (.type? == "string" and has("pattern")) then
				.pattern
			else
				"string"
			end
    end;

  gen($full; "")
  ' "$TMP"

  rm -f "$TMP"
  exit 0
fi

# ============================
# ENDPOINTS
# ============================
echo
echo "📡 Endpoints:"

for file in $RAML_FILES; do
  curl -s \
    "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file" \
  | awk '
    /^[\/]/ { path=$1 }
    /^[ ]+(get|post|put|delete|patch):/ {
      method=toupper($1)
      gsub(":", "", method)
      if (path != "") print method, path
    }
  '
done | sort -u

echo

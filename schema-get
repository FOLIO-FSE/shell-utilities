#!/usr/bin/env bash
set -euo pipefail

# ----------------------------
# Requirements
# ----------------------------
command -v curl >/dev/null || { echo "❌ curl required"; exit 1; }
command -v jq >/dev/null || { echo "❌ jq required"; exit 1; }

QUERY="${1:-}"
MODE="${2:-}"
ARG="${3:-}"

METHOD_FILTER="${2:-}"
METHOD_FILTER="${METHOD_FILTER^^}"

if [[ -z "$QUERY" ]]; then
  echo "Usage:"
  echo "  schema-get <module>"
  echo "  schema-get <module> GET|POST"
  echo "  schema-get <module> schema <name>"
  exit 1
fi

# ----------------------------
# ✅ HEADERS (fix rate limit)
# ----------------------------
HEADERS=(
  -H "Accept: application/vnd.github+json"
  -H "User-Agent: schema-get"
)

if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  HEADERS+=(-H "Authorization: token $GITHUB_TOKEN")
fi

# ----------------------------
# ✅ MODULE RESOLUTION (robust)
# ----------------------------
Q=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')

if [[ "$Q" == *s ]]; then
  BASE="${Q%s}"
else
  BASE="$Q"
fi

CANDIDATES=(
  "mod-$BASE"
  "mod-${BASE}s"
)

MODULE=""

for m in "${CANDIDATES[@]}"; do
  RESPONSE=$(curl -s "${HEADERS[@]}" \
    "https://api.github.com/repos/folio-org/$m")

  EXISTS=$(echo "$RESPONSE" | jq -r '.id // empty')

  if [[ -n "$EXISTS" ]]; then
    MODULE="$m"
    break
  fi
done

if [[ -z "$MODULE" ]]; then
  echo "❌ Module not found for: $QUERY"
  exit 1
fi

echo "🔍 Module: $MODULE"

# ----------------------------
# Branch
# ----------------------------
BRANCH=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE" \
  | jq -r '.default_branch')

echo "🌿 Branch: $BRANCH"

# ----------------------------
# RAML files
# ----------------------------
RAMLS_JSON=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE/contents/ramls")

RAML_FILES=$(echo "$RAMLS_JSON" | jq -r '
  .[]? | select(.name | endswith(".raml")) | .path
')

# ============================
# ✅ SCHEMA MODE
# ============================
if [[ "$MODE" == "schema" ]]; then
  if [[ -z "$ARG" ]]; then
    echo "Usage: schema-get <module> schema <name>"
    exit 1
  fi

  NAME=$(echo "$ARG" | tr '[:upper:]' '[:lower:]')
  echo "🔎 Searching for schema: $NAME"

  FOUND_PATH=""
  FOUND_FILE=""

  for file in $RAML_FILES; do
    CONTENT=$(curl -s \
      "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

    SCHEMAS=$(echo "$CONTENT" | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' || true)

    # ✅ 1. exact match
    MATCH=$(echo "$SCHEMAS" \
      | grep -Ei "/${NAME}\.json$" \
      | head -n1 || true)

    # ✅ 2. composite fallback
    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" \
        | grep -Ei "composite_${NAME}\.json$" \
        | head -n1 || true)
    fi

    # ✅ 3. final fallback
    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" \
        | grep -Ei "$NAME" \
        | head -n1 || true)
    fi

    if [[ -n "$MATCH" ]]; then
      FOUND_PATH="$MATCH"
      FOUND_FILE=$(basename "$MATCH")
      break
    fi
  done

  if [[ -z "$FOUND_FILE" ]]; then
    echo "❌ Schema not found in RAML"
    exit 1
  fi

TMP=$(mktemp)

URL1="https://raw.githubusercontent.com/folio-org/acq-models/master/${MODULE}/schemas/${FOUND_FILE}"
URL2="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$FOUND_PATH"

HTTP1=$(curl -s -w "%{http_code}" -o "$TMP" "$URL1")

if [[ "$HTTP1" == "200" ]]; then
  SCHEMA_URL="$URL1"
else
  HTTP2=$(curl -s -w "%{http_code}" -o "$TMP" "$URL2")

  if [[ "$HTTP2" == "200" ]]; then
    SCHEMA_URL="$URL2"
  else
    echo "⚠️ Schema '$FOUND_FILE' is referenced but not a standalone schema file"
    rm -f "$TMP"
    exit 1
  fi
fi

echo "📦 Schema: $FOUND_FILE"
echo "🔗 URL: $SCHEMA_URL"
echo

cat "$TMP" | jq .
rm -f "$TMP"

  exit 0
fi

# ============================
# Endpoints
# ============================
echo
echo "📡 Endpoints:"

for file in $RAML_FILES; do
  CONTENT=$(curl -s \
    "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

  echo "$CONTENT" | awk '
    /^[\/]/ { path=$1 }
    /^[ ]+(get|post|put|delete|patch):/ {
      method=toupper($1)
      gsub(":", "", method)
      if (path != "") print method, path
    }
  '
done | sort -u | awk -v f="$METHOD_FILTER" '
  f=="" || $1==f { print }
'

# ============================
# Schema list
# ============================
echo
echo "📦 Schemas referenced in RAML:"

for file in $RAML_FILES; do
  curl -s \
    "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file"
done | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' | sort -u

#!/usr/bin/env bash
set -euo pipefail

command -v curl >/dev/null || { echo "❌ curl required"; exit 1; }
command -v jq >/dev/null || { echo "❌ jq required"; exit 1; }

QUERY="${1:-}"
MODE="${2:-}"
ARG="${3:-}"

if [[ -z "$QUERY" ]]; then
  echo "Usage:"
  echo "  schema-get <module>"
  echo "  schema-get <module> schema <name>"
  echo "  schema-get <module> example <name>"
  echo "  schema-get <module> example-full <name>"
  exit 1
fi

# ----------------------------
# GitHub headers
# ----------------------------
HEADERS=(-H "Accept: application/vnd.github+json" -H "User-Agent: schema-get")
if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  HEADERS+=(-H "Authorization: token $GITHUB_TOKEN")
fi

# ----------------------------
# MODULE RESOLUTION
# ----------------------------
Q=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')
BASE="${Q%s}"

CANDIDATES=("mod-$BASE" "mod-${BASE}s")
MODULE=""

for m in "${CANDIDATES[@]}"; do
  RESP=$(curl -s "${HEADERS[@]}" "https://api.github.com/repos/folio-org/$m")
  if [[ "$(echo "$RESP" | jq -r '.id // empty')" != "" ]]; then
    MODULE="$m"
    break
  fi
done

[[ -z "$MODULE" ]] && { echo "❌ Module not found"; exit 1; }

echo "🔍 Module: $MODULE"

# ----------------------------
# Branch
# ----------------------------
BRANCH=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE" \
  | jq -r '.default_branch')

echo "🌿 Branch: $BRANCH"

# ----------------------------
# RAML files
# ----------------------------
RAML_FILES=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE/contents/ramls" \
  | jq -r '.[]? | select(.name|endswith(".raml")) | .path')

# ----------------------------
# FIND SCHEMA
# ----------------------------
find_schema() {
  local name="$1"
  local sc_path=""
  local sc_file=""

  for file in $RAML_FILES; do
    CONTENT=$(curl -s \
      "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

    SCHEMAS=$(echo "$CONTENT" | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' || true)

    MATCH=$(echo "$SCHEMAS" | grep -Ei "$name" | head -n1 || true)

    if [[ -n "$MATCH" ]]; then
      sc_path="$MATCH"
      sc_file=$(basename "$MATCH")
      break
    fi
  done

  echo "$sc_path|$sc_file"
}

# ----------------------------
# FETCH SCHEMA
# ----------------------------
fetch_schema() {
  local file="$1"
  local path="$2"
  local tmp="$3"

  URL1="https://raw.githubusercontent.com/folio-org/acq-models/master/$MODULE/schemas/$file"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL1")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL1"
    return
  fi

  URL2="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$path"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL2")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL2"
    return
  fi

  echo ""
}

# ============================
# ✅ SCHEMA MODE
# ============================
if [[ "$MODE" == "schema" ]]; then

  # ✅ If no schema name → list available schemas
  if [[ -z "$ARG" ]]; then
    echo
    echo "📦 Available schemas:"
    echo

    for file in $RAML_FILES; do
      CONTENT=$(curl -s \
        "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

      echo "$CONTENT" \
        | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' \
        | sed 's#.*/##' \
        | sort -u
    done

    echo
    echo "💡 Usage:"
    echo "   schema-get $QUERY schema <name>"
    echo
    exit 0
  fi

  IFS="|" read SCHEMA_PATH SCHEMA_FILE <<< "$(find_schema "$ARG")"
  [[ -z "$SCHEMA_FILE" ]] && { echo "❌ schema not found"; exit 1; }

  TMP=$(/usr/bin/mktemp)
  URL=$(fetch_schema "$SCHEMA_FILE" "$SCHEMA_PATH" "$TMP")

  [[ -z "$URL" ]] && {
    echo "⚠️ schema not standalone"
    exit 1
  }

  echo "📦 Schema: $SCHEMA_FILE"
  echo "🔗 URL: $URL"
  echo

  jq . "$TMP"

  rm -f "$TMP"
  exit 0
fi

# ============================
# ✅ EXAMPLE / EXAMPLE-FULL
# ============================
if [[ "$MODE" == example* ]]; then
  [[ -z "$ARG" ]] && { echo "❌ provide schema name"; exit 1; }

  FULL=false
  [[ "$MODE" == "example-full" ]] && FULL=true

  IFS="|" read SCHEMA_PATH SCHEMA_FILE <<< "$(find_schema "$ARG")"
  [[ -z "$SCHEMA_FILE" ]] && { echo "❌ schema not found"; exit 1; }

  TMP=$(/usr/bin/mktemp)
  URL=$(fetch_schema "$SCHEMA_FILE" "$SCHEMA_PATH" "$TMP")

  [[ -z "$URL" ]] && { echo "❌ schema fetch failed"; exit 1; }

  echo "🧪 $( $FULL && echo Full || echo Minimal ) payload for: $SCHEMA_FILE"
  echo

  jq --argjson full "$FULL" '
def uuid: "00000000-0000-0000-0000-000000000000";

def guess($k):
  if ($k == "workflowStatus") then ["Open","Pending","Closed"]
  elif ($k|test("id$|Id$|vendor|assignedTo|openedById|approvedById|billTo|shipTo|template|fiscalYearId")) then uuid
  elif ($k|test("date")) then "2026-01-01T00:00:00Z"
  elif ($k|test("number|Number|total|amount")) then 0
  elif ($k|test("approved|manual|ongoing|reEncumber|needReEncumber")) then false
  else "string"
  end;

def isArray:
  has("items") or (.type? == "array");

def isObject:
  has("properties") or (.type? == "object");

def gen($full; $key):

  # ✅ ARRAY FIRST (never fall through)
  if isArray then
    []

  # ✅ ENUMS BEFORE ANYTHING ELSE
# ✅ SAFE enum detection (local only)
elif has("enum") then
  .enum

# ✅ also handle enums in allOf (common FOLIO pattern)
elif has("allOf") and (.allOf | type == "array") then
  (.allOf[] | select(has("enum")) | .enum) // empty

  # ✅ REF
  elif has("$ref") then
    if ($key == "workflowStatus") then ["Open","Pending","Closed"]
    else guess($key)
    end

  # ✅ SCALARS
  elif (.type? == "boolean") then false
  elif (.type? == "integer") then 0
  elif (.type? == "number") then 0

  # ✅ OBJECTS (THIS IS WHERE MINIMAL LOGIC GOES)
  elif isObject then
    (.properties // {}) as $props
    | (.required // []) as $req

    | if $full then
        # FULL → everything
        reduce ($props | keys_unsorted[]) as $k (
          {};
          . + { ($k): ($props[$k] | gen($full; $k)) }
        )
      else
        # MINIMAL → only required fields
        if ($req | length) > 0 then
          reduce $req[] as $k (
            {};
            . + { ($k): ($props[$k] | gen($full; $k)) }
          )
        else
          # fallback: if no required defined
          reduce ($props | keys_unsorted[]) as $k (
            {};
            . + { ($k): ($props[$k] | gen($full; $k)) }
          )
        end
      end

  # ✅ STRING
  elif (.type? == "string") then
    guess($key)

  # ✅ FINAL FALLBACK
  else
    guess($key)
  end;

gen($full; "")
  ' "$TMP"

  rm -f "$TMP"
  exit 0
fi

# ============================
# ✅ ENDPOINTS (fallback)
# ============================
echo
echo "📡 Endpoints:"

for file in $RAML_FILES; do
  curl -s \
  "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file" \
  | awk '
    /^[\/]/ { path=$1 }
    /^[ ]+(get|post|put|delete|patch):/ {
      method=toupper($1)
      gsub(":", "", method)
      if (path != "") print method, path
    }
  '
done | sort -u

echo


#!/usr/bin/env bash
set -euo pipefail

# ----------------------------
# Setup
# ----------------------------
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

command -v curl >/dev/null || { echo "❌ curl required"; exit 1; }
command -v jq >/dev/null || { echo "❌ jq required"; exit 1; }

QUERY="${1:-}"
MODE="${2:-}"
ARG="${3:-}"

METHOD_FILTER="${2:-}"
METHOD_FILTER="${METHOD_FILTER^^}"

if [[ -z "$QUERY" ]]; then
  echo "Usage:"
  echo "  schema-get <module>"
  echo "  schema-get <module> GET|POST"
  echo "  schema-get <module> schema <name>"
  exit 1
fi

HEADERS=(-H "Accept: application/vnd.github+json" -H "User-Agent: schema-get")

# ----------------------------
# Normalize module
# ----------------------------
Q=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')
Q=${Q%s}
MODULE="mod-${Q}s"

echo "🔍 Module: $MODULE"

# ----------------------------
# Get branch
# ----------------------------
BRANCH=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE" \
  | jq -r '.default_branch')

if [[ "$BRANCH" == "null" || -z "$BRANCH" ]]; then
  echo "❌ Module not found"
  exit 1
fi

echo "🌿 Branch: $BRANCH"

# ----------------------------
# Get RAML files
# ----------------------------
RAMLS_JSON=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE/contents/ramls")

RAML_FILES=$(echo "$RAMLS_JSON" | jq -r '
  .[]? | select(.name | endswith(".raml")) | .path
')

# ----------------------------
# ✅ SCHEMA MODE (FINAL)
# ----------------------------
if [[ "$MODE" == "schema" ]]; then
  if [[ -z "$ARG" ]]; then
    echo "Usage: schema-get <module> schema <name>"
    exit 1
  fi

  NAME=$(echo "$ARG" | tr '[:upper:]' '[:lower:]')

  echo "🔎 Searching for schema: $NAME"

  FOUND_FILE=""

  for file in $RAML_FILES; do
    CONTENT=$(curl -s "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

    SCHEMAS=$(echo "$CONTENT" | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' || true)

    # ✅ 1. exact match
    MATCH=$(echo "$SCHEMAS" \
      | grep -Ei "/${NAME}\.json$" \
      | head -n1 || true)

    # ✅ 2. composite fallback (IMPORTANT FIX)
    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" \
        | grep -Ei "composite_${NAME}\.json$" \
        | head -n1 || true)
    fi

    # ✅ 3. final fallback
    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" \
        | grep -Ei "$NAME" \
        | head -n1 || true)
    fi

    if [[ -n "$MATCH" ]]; then
      FOUND_FILE=$(basename "$MATCH")
      break
    fi
  done

  if [[ -z "$FOUND_FILE" ]]; then
    echo "❌ Schema not found in RAML"
    exit 1
  fi

  # ✅ Correct source: acq-models
  SCHEMA_URL="https://raw.githubusercontent.com/folio-org/acq-models/master/${MODULE}/schemas/${FOUND_FILE}"

  echo "📦 Schema: $FOUND_FILE"
  echo "🔗 URL: $SCHEMA_URL"
  echo

  TMP=$(mktemp)
  HTTP_CODE=$(curl -s -w "%{http_code}" -o "$TMP" "$SCHEMA_URL")

  if [[ "$HTTP_CODE" != "200" ]]; then
    echo "❌ Failed to fetch schema (HTTP $HTTP_CODE)"
    rm -f "$TMP"
    exit 1
  fi

  cat "$TMP" | jq .
  rm -f "$TMP"

  exit 0
fi

# ----------------------------
# Endpoints
# ----------------------------
echo
echo "📡 Endpoints:"

for file in $RAML_FILES; do
  CONTENT=$(curl -s "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

  echo "$CONTENT" | awk '
    /^[\/]/ { path=$1 }
    /^[ ]+(get|post|put|delete|patch):/ {
      method=toupper($1)
      gsub(":", "", method)
      if (path != "") print method, path
    }
  '
done | sort -u | awk -v f="$METHOD_FILTER" '
  f=="" || $1==f { print }
'

# ----------------------------
# Schemas list
# ----------------------------
echo
echo "📦 Schemas referenced in RAML:"

for file in $RAML_FILES; do
  curl -s "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file"
done | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' | sort -u


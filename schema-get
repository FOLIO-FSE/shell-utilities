#!/usr/bin/env bash
set -euo pipefail

command -v curl >/dev/null || { echo "❌ curl required"; exit 1; }
command -v jq >/dev/null || { echo "❌ jq required"; exit 1; }

QUERY="${1:-}"
MODE="${2:-}"
ARG="${3:-}"

if [[ -z "$QUERY" ]]; then
  echo "Usage:"
  echo "  schema-get <module>"
  echo "  schema-get <module> GET|POST"
  echo "  schema-get <module> schema <name>"
  echo "  schema-get <module> example <name>"
  exit 1
fi

# ----------------------------
# GitHub headers
# ----------------------------
HEADERS=(
  -H "Accept: application/vnd.github+json"
  -H "User-Agent: schema-get"
)

if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  HEADERS+=(-H "Authorization: token $GITHUB_TOKEN")
fi

# ----------------------------
# MODULE RESOLUTION
# ----------------------------
Q=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')

BASE="${Q%s}"

CANDIDATES=("mod-$BASE" "mod-${BASE}s")

MODULE=""

for m in "${CANDIDATES[@]}"; do
  RESP=$(curl -s "${HEADERS[@]}" "https://api.github.com/repos/folio-org/$m")
  if [[ "$(echo "$RESP" | jq -r '.id // empty')" != "" ]]; then
    MODULE="$m"
    break
  fi
done

if [[ -z "$MODULE" ]]; then
  echo "❌ Module not found for: $QUERY"
  exit 1
fi

echo "🔍 Module: $MODULE"

# ----------------------------
# Branch
# ----------------------------
BRANCH=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE" \
  | jq -r '.default_branch')

echo "🌿 Branch: $BRANCH"

# ----------------------------
# RAML files
# ----------------------------
RAML_FILES=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE/contents/ramls" \
  | jq -r '.[]? | select(.name|endswith(".raml")) | .path')

# ----------------------------
# ✅ COMMON: FIND SCHEMA
# ----------------------------
find_schema() {
  local name="$1"
  local found_path=""
  local found_file=""

  for file in $RAML_FILES; do
    CONTENT=$(curl -s \
      "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

    SCHEMAS=$(echo "$CONTENT" | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' || true)

    MATCH=$(echo "$SCHEMAS" | grep -Ei "/${name}\.json$" | head -n1 || true)

    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" | grep -Ei "composite_${name}\.json$" | head -n1 || true)
    fi

    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" | grep -Ei "$name" | head -n1 || true)
    fi

    if [[ -n "$MATCH" ]]; then
      found_path="$MATCH"
      found_file=$(basename "$MATCH")
      break
    fi
  done

  echo "$found_path|$found_file"
}

# ============================
# ✅ SCHEMA MODE
# ============================
if [[ "$MODE" == "schema" ]]; then
  [[ -z "$ARG" ]] && { echo "❌ Provide schema name"; exit 1; }

  IFS="|" read FOUND_PATH FOUND_FILE <<< "$(find_schema "$ARG")"

  [[ -z "$FOUND_FILE" ]] && { echo "❌ Schema not found"; exit 1; }

  TMP=$(mktemp)

  URL1="https://raw.githubusercontent.com/folio-org/acq-models/master/$MODULE/schemas/$FOUND_FILE"
  HTTP=$(curl -s -w "%{http_code}" -o "$TMP" "$URL1")

  if [[ "$HTTP" != "200" ]]; then
    URL2="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$FOUND_PATH"
    HTTP=$(curl -s -w "%{http_code}" -o "$TMP" "$URL2")
    SCHEMA_URL="$URL2"
  else
    SCHEMA_URL="$URL1"
  fi

  if [[ "$HTTP" != "200" ]]; then
    echo "⚠️ Schema exists logically but not as standalone file"
    exit 1
  fi

  echo "📦 Schema: $FOUND_FILE"
  echo "🔗 URL: $SCHEMA_URL"
  echo

  jq . "$TMP"
  rm -f "$TMP"
  exit 0
fi

# ============================
# ✅ EXAMPLE MODE (FIXED)
# ============================
if [[ "$MODE" == "example" ]]; then
  [[ -z "$ARG" ]] && { echo "❌ Provide schema name"; exit 1; }

  IFS="|" read FOUND_PATH FOUND_FILE <<< "$(find_schema "$ARG")"

  [[ -z "$FOUND_FILE" ]] && { echo "❌ Schema not found"; exit 1; }

  TMP=$(mktemp)

  URL1="https://raw.githubusercontent.com/folio-org/acq-models/master/$MODULE/schemas/$FOUND_FILE"
  HTTP=$(curl -s -w "%{http_code}" -o "$TMP" "$URL1")

  if [[ "$HTTP" != "200" ]]; then
    URL2="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$FOUND_PATH"
    HTTP=$(curl -s -w "%{http_code}" -o "$TMP" "$URL2")
  fi

  if [[ "$HTTP" != "200" ]]; then
    echo "❌ Could not fetch schema"
    exit 1
  fi

  echo "🧪 Example payload for: $FOUND_FILE"
  echo

  # ✅ FIXED jq generator (no null-key crash)
jq '
# ----------------------------
# Resolve references (basic)
# ----------------------------
def resolve:
  if type == "object" and has("$ref") then
    # Just indicate reference (no recursion yet)
    "ref:" + .["$ref"]
  else
    .
  end;

# ----------------------------
# Generate example
# ----------------------------
def gen:
  resolve
  | if type == "object" then
      if has("properties") then
        reduce (.properties | keys_unsorted[]) as $k (
          {};
          . + { ($k): (.properties[$k] | gen) }
        )
      else
        {}
      end
    elif type == "array" then
      [ (.items | gen) ]
    elif type == "string" then
      if has("enum") then .enum[0]
      else "string" end
    elif type == "integer" then 0
    elif type == "number" then 0
    elif type == "boolean" then false
    else null
  end;

# ----------------------------
# Entry point
# ----------------------------
gen
' "$TMP"
  rm -f "$TMP"
  exit 0
fi

# ============================
# ✅ ENDPOINTS MODE
# ============================
echo
echo "📡 Endpoints:"

for file in $RAML_FILES; do
  CONTENT=$(curl -s \
    "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

  echo "$CONTENT" | awk '
    /^[\/]/ { path=$1 }
    /^[ ]+(get|post|put|delete|patch):/ {
      method=toupper($1)
      gsub(":", "", method)
      if (path != "") print method, path
    }
  '
done | sort -u

echo

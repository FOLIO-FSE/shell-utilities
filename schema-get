#!/usr/bin/env bash
set -euo pipefail

command -v curl >/dev/null || { echo "❌ curl required"; exit 1; }
command -v jq >/dev/null || { echo "❌ jq required"; exit 1; }

QUERY="${1:-}"
MODE="${2:-}"
ARG="${3:-}"

if [[ -z "$QUERY" ]]; then
  echo "Usage:"
  echo "  schema-get <module>"
  echo "  schema-get <module> GET|POST"
  echo "  schema-get <module> schema <name>"
  echo "  schema-get <module> example <name>"
  echo "  schema-get <module> example-full <name>"
  exit 1
fi

# ----------------------------
# GitHub headers
# ----------------------------
HEADERS=(-H "Accept: application/vnd.github+json" -H "User-Agent: schema-get")
if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  HEADERS+=(-H "Authorization: token $GITHUB_TOKEN")
fi

# ----------------------------
# Module resolution
# ----------------------------
Q=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')
BASE="${Q%s}"
CANDIDATES=("mod-$BASE" "mod-${BASE}s")

MODULE=""
for m in "${CANDIDATES[@]}"; do
  RESP=$(curl -s "${HEADERS[@]}" "https://api.github.com/repos/folio-org/$m")
  if [[ "$(echo "$RESP" | jq -r '.id // empty')" != "" ]]; then
    MODULE="$m"
    break
  fi
done

[[ -z "$MODULE" ]] && { echo "❌ Module not found"; exit 1; }

echo "🔍 Module: $MODULE"

BRANCH=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE" \
  | jq -r '.default_branch')

echo "🌿 Branch: $BRANCH"

RAML_FILES=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE/contents/ramls" \
  | jq -r '.[]? | select(.name|endswith(".raml")) | .path')

# ----------------------------
# Find schema
# ----------------------------
find_schema() {
  local name="$1"
  local sc_path=""
  local sc_file=""

  for file in $RAML_FILES; do
    CONTENT=$(curl -s \
      "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

    SCHEMAS=$(echo "$CONTENT" | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' || true)

    MATCH=$(echo "$SCHEMAS" | grep -Ei "/${name}\.json$" | head -n1 || true)

    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" | grep -Ei "composite_${name}\.json$" | head -n1 || true)
    fi

    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" | grep -Ei "$name" | head -n1 || true)
    fi

    if [[ -n "$MATCH" ]]; then
      sc_path="$MATCH"
      sc_file=$(basename "$MATCH")
      break
    fi
  done

  echo "$sc_path|$sc_file"
}

# ----------------------------
# Fetch schema
# ----------------------------
fetch_schema() {
  local file="$1"
  local path="$2"
  local tmp="$3"

  URL1="https://raw.githubusercontent.com/folio-org/acq-models/master/$MODULE/schemas/$file"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL1")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL1"
    return
  fi

  URL2="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$path"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL2")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL2"
    return
  fi

  echo ""
}

# ============================
# EXAMPLE MODES
# ============================
if [[ "$MODE" == example* ]]; then
  [[ -z "$ARG" ]] && { echo "❌ provide schema name"; exit 1; }

  FULL=false
  [[ "$MODE" == "example-full" ]] && FULL=true

  IFS="|" read SCHEMA_PATH SCHEMA_FILE <<< "$(find_schema "$ARG")"
  [[ -z "$SCHEMA_FILE" ]] && { echo "❌ schema not found"; exit 1; }

  TMP=$(/usr/bin/mktemp)
  URL=$(fetch_schema "$SCHEMA_FILE" "$SCHEMA_PATH" "$TMP")

  [[ -z "$URL" ]] && { echo "❌ schema fetch failed"; exit 1; }

  echo "🧪 $( $FULL && echo Full || echo Minimal ) payload for: $SCHEMA_FILE"
  echo

  jq --argjson full "$FULL" '

def guess($k):

  # ✅ MUST BE FIRST (prevents fallthrough)
  if ($k == "workflowStatus") then
    ["Open", "Pending", "Closed"]

  # ✅ UUID-like fields
  elif ($k|test("id$|Id$|vendor|assignedTo|openedById|approvedById|billTo|shipTo|template|fiscalYearId")) then
    "00000000-0000-0000-0000-000000000000"

  # ✅ Dates
  elif ($k|test("date")) then
    "2026-01-01T00:00:00Z"

  # ✅ Numbers
  elif ($k|test("number|Number|total|amount")) then
    0

  # ✅ Booleans
  elif ($k|test("approved|manual|ongoing|reEncumber|needReEncumber")) then
    false

  # ✅ Default
  else
    "string"
  end;


def isArray:
  has("items") or (.type? == "array");

def isObject:
  has("properties") or (.type? == "object");

def gen($full; $key):

  # ✅ ARRAY (hard stop — no recursion leakage)
  if isArray then
    []

  # ✅ ENUM (must come before string handling)
  elif has("enum") then
    .enum

  # ✅ REF
  elif has("$ref") then
    guess($key)

  # ✅ SCALAR TYPES
  elif (.type? == "boolean") then false
  elif (.type? == "integer") then 0
  elif (.type? == "number") then 0

  # ✅ OBJECT
  elif isObject then
    (.properties // {}) as $props
    |
    reduce ($props | keys_unsorted[]) as $k (
      {};
      . + { ($k): ($props[$k] | gen($full; $k)) }
    )

  # ✅ STRING
  elif (.type? == "string") then
    guess($key)

  # ✅ FALLBACK
  else
    guess($key)
  end;

gen($full; "")
  ' "$TMP"

  rm -f "$TMP"
  exit 0
fi

# ============================
# ENDPOINTS
# ============================
echo
echo "📡 Endpoints:"

for file in $RAML_FILES; do
  curl -s \
    "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file" \
  | awk '
    /^[\/]/ { path=$1 }
    /^[ ]+(get|post|put|delete|patch):/ {
      method=toupper($1)
      gsub(":", "", method)
      if (path != "") print method, path
    }
  '
done | sort -u

echo

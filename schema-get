#!/usr/bin/env bash
set -euo pipefail

command -v curl >/dev/null || { echo "❌ curl required"; exit 1; }
command -v jq >/dev/null || { echo "❌ jq required"; exit 1; }

QUERY="${1:-}"
MODE="${2:-}"
ARG="${3:-}"

if [[ -z "$QUERY" ]]; then
  echo "Usage:"
  echo "  schema-get <module>"
  echo "  schema-get <module> GET|POST"
  echo "  schema-get <module> schema <name>"
  echo "  schema-get <module> example <name>"
  echo "  schema-get <module> example-full <name>"
  exit 1
fi

# ----------------------------
# GitHub headers
# ----------------------------
HEADERS=(
  -H "Accept: application/vnd.github+json"
  -H "User-Agent: schema-get"
)

if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  HEADERS+=(-H "Authorization: token $GITHUB_TOKEN")
fi

# ----------------------------
# MODULE RESOLUTION
# ----------------------------
Q=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]')
BASE="${Q%s}"

CANDIDATES=("mod-$BASE" "mod-${BASE}s")
MODULE=""

for m in "${CANDIDATES[@]}"; do
  RESP=$(curl -s "${HEADERS[@]}" "https://api.github.com/repos/folio-org/$m")
  if [[ "$(echo "$RESP" | jq -r '.id // empty')" != "" ]]; then
    MODULE="$m"
    break
  fi
done

[[ -z "$MODULE" ]] && { echo "❌ Module not found for: $QUERY"; exit 1; }

echo "🔍 Module: $MODULE"

# ----------------------------
# Get branch
# ----------------------------
BRANCH=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE" \
  | jq -r '.default_branch')

echo "🌿 Branch: $BRANCH"

# ----------------------------
# RAML files
# ----------------------------
RAML_FILES=$(curl -s "${HEADERS[@]}" \
  "https://api.github.com/repos/folio-org/$MODULE/contents/ramls" \
  | jq -r '.[]? | select(.name|endswith(".raml")) | .path')

# ----------------------------
# FIND SCHEMA
# ----------------------------
find_schema() {
  local name="$1"
  local found_path=""
  local found_file=""

  for file in $RAML_FILES; do
    CONTENT=$(curl -s \
      "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

    SCHEMAS=$(echo "$CONTENT" | grep -Eo 'schemas/[A-Za-z0-9_./-]+\.json' || true)

    MATCH=$(echo "$SCHEMAS" | grep -Ei "/${name}\.json$" | head -n1 || true)

    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" | grep -Ei "composite_${name}\.json$" | head -n1 || true)
    fi

    if [[ -z "$MATCH" ]]; then
      MATCH=$(echo "$SCHEMAS" | grep -Ei "$name" | head -n1 || true)
    fi

    if [[ -n "$MATCH" ]]; then
      found_path="$MATCH"
      found_file=$(basename "$MATCH")
      break
    fi
  done

  echo "$found_path|$found_file"
}

# ----------------------------
# FETCH SCHEMA FILE
# ----------------------------
fetch_schema() {
  local file="$1"
  local path="$2"
  local tmp="$3"

  URL1="https://raw.githubusercontent.com/folio-org/acq-models/master/$MODULE/schemas/$file"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL1")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL1"
    return
  fi

  URL2="https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/ramls/$path"
  HTTP=$(curl -s -w "%{http_code}" -o "$tmp" "$URL2")

  if [[ "$HTTP" == "200" ]]; then
    echo "$URL2"
    return
  fi

  echo ""
}

# ============================
# SCHEMA MODE
# ============================
if [[ "$MODE" == "schema" ]]; then
  [[ -z "$ARG" ]] && { echo "❌ provide schema name"; exit 1; }

  IFS="|" read SCHEMA_PATH FILE <<< "$(find_schema "$ARG")"

  [[ -z "$FILE" ]] && { echo "❌ schema not found"; exit 1; }

  TMP=$(mktemp)
  URL=$(fetch_schema "$FILE" "$SCHEMA_PATH" "$TMP")

  [[ -z "$URL" ]] && {
    echo "⚠️ Schema referenced but not standalone"
    exit 1
  }

  echo "📦 Schema: $FILE"
  echo "🔗 URL: $URL"
  echo

  jq . "$TMP"
  rm -f "$TMP"
  exit 0
fi

# ============================
# EXAMPLE / EXAMPLE-FULL
# ============================
if [[ "$MODE" == example* ]]; then
  [[ -z "$ARG" ]] && { echo "❌ provide schema name"; exit 1; }

  FULL=false
  [[ "$MODE" == "example-full" ]] && FULL=true

  IFS="|" read SCHEMA_PATH FILE <<< "$(find_schema "$ARG")"

  [[ -z "$FILE" ]] && { echo "❌ schema not found"; exit 1; }

  TMP=$(mktemp)
  URL=$(fetch_schema "$FILE" "$SCHEMA_PATH" "$TMP")

  [[ -z "$URL" ]] && {
    echo "❌ could not fetch schema"
    exit 1
  }

  echo "🧪 $( $FULL && echo Full || echo Minimal ) payload for: $FILE"
  echo

jq --argjson full "$FULL" '

# ----------------------------
# Heuristic values
# ----------------------------
def guess($key):
  if ($key|test("id$|Id$")) then "00000000-0000-0000-0000-000000000000"
  elif ($key|test("date")) then "2026-01-01T00:00:00Z"
  elif ($key|test("number|Number")) then "PO-0001"
  else "string"
  end;

# ----------------------------
# Generator
# ----------------------------
def gen($full; $key):

  if has("$ref") then
    guess($key)

  elif type == "object" then
    (.properties // {}) as $props
    | (.required // []) as $req

    | if ($props | length) == 0 then
        # fallback when schema is empty object
        guess($key)

      else
        if $full then
          reduce ($props | keys_unsorted[]) as $k (
            {}; . + { ($k): ($props[$k] | gen($full; $k)) })
        else
          if ($req | length) > 0 then
            reduce $req[] as $k (
              {}; . + { ($k): ($props[$k] | gen($full; $k)) })
          else
            reduce ($props | keys_unsorted[]) as $k (
              {}; . + { ($k): ($props[$k] | gen($full; $k)) })
          end
        end
      end

  elif type == "array" then
    [ (.items | gen($full; $key)) ]

  elif type == "string" then
    if has("enum") then .enum[0]
    else guess($key)
    end

  elif type == "boolean" then false
  elif type == "integer" then 0
  elif type == "number" then 0

  else guess($key)
  end;

gen($full; "")
' "$TMP"

  rm -f "$TMP"
  exit 0
fi

# ============================
# ENDPOINTS
# ============================
echo
echo "📡 Endpoints:"

for file in $RAML_FILES; do
  CONTENT=$(curl -s \
    "https://raw.githubusercontent.com/folio-org/$MODULE/$BRANCH/$file")

  echo "$CONTENT" | awk '
    /^[\/]/ { path=$1 }
    /^[ ]+(get|post|put|delete|patch):/ {
      method=toupper($1)
      gsub(":", "", method)
      if (path != "") print method, path
    }
  '
done | sort -u

echo

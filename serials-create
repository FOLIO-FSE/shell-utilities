create_serial() {
	title=$(
	  curl -s -X GET \
	    -H "Accept: application/json" \
	    -H "X-Okapi-Tenant: ${tenant}" \
	    -H "x-okapi-token: ${okapi_token}" \
	    "${okapi_url}/orders-storage/po-lines/${pol_uuid}" |
	  jq -r '.titleOrPackage // empty' 2>/dev/null
	)
	
	titleId=$(
	  curl -s -X GET \
	    -H "Accept: application/json" \
	    -H "X-Okapi-Tenant: ${tenant}" \
	    -H "x-okapi-token: ${okapi_token}" \
	    "${okapi_url}/orders-storage/titles?query=poLineId==${pol_uuid}" |
	  jq -r '.title // empty' 2>/dev/null
	)

IFS='' read -r -d '' serial << EndOfJSON
{
  "serialStatus": "active",
  "description": "${description}",
  "orderLine": {
		"remoteId": "${pol_uuid}",
		"title": "${title}",
		"titleId": "${titleId}"
	}
}
EndOfJSON
}

numserials=$(cat ${serials_file} |wc -l)

#while IFS=$'\t' read -r instance_uuid pol_uuid template_uuid description; do
while IFS=$'\t' read -r instance_uuid pol_uuid frequency description; do
	echo -en "Processing record $counter of ${numserials}.\r"

	create_serial

	serial_response=$(curl --http1.1 -s -w '\n' -X POST -H "Content-type: application/json" -H "X-Okapi-Tenant: ${tenant}" -H "x-okapi-token: ${okapi_token}" -d "${serial}" "${okapi_url}/serials-management/serials")
	echo -e "${serial_response//$'\n'/ }" >> ${logfile}

	serial_uuid=$(jq -r .id <<< "${serial_response}")

	frequency="${frequency,,}"	
	frequency="${frequency//[^a-z0-9]/}"	

	case "${frequency}" in
		triennial)    ruleset="${triennial}" ;;
		biennial)    ruleset="${biennial}" ;;
		annual|yearly)    ruleset="${annual}" ;;
		semiannual)    ruleset="${semiannual}" ;;
		triannual)    ruleset="${triannual}" ;;
		quarterly) ruleset="${quarterly}" ;;
		bimonthly)   ruleset="${bimonthly}" ;;
		monthly)   ruleset="${monthly}" ;;
		semimonthly)   ruleset="${semimonthly}" ;;
		weekly)    ruleset="${weekly}" ;;
		biweekly)    ruleset="${biweekly}" ;;
		daily)     ruleset="${daily}" ;;
	esac

	ruleset=$(jq -c --arg serial_uuid ${serial_uuid} '.owner.id = $serial_uuid' <<< "${ruleset}")

	pub_pattern_response=$(curl -i --http1.1 -s -w '\n' -X POST -H "Content-type: application/json" -H "X-Okapi-Tenant: ${tenant}" -H "x-okapi-token: ${okapi_token}" -d "${ruleset}" "${okapi_url}/serials-management/rulesets")
	echo -e "${ruleset//$'\n'/ }" >> ${logfile}
	echo -e "${pub_pattern_response//$'\n'/ }" >> ${logfile}

done < ${serials_file}
echo 
echo "Processing completed. Server responses are output to ${logfile}"
